# Papyr backend production environment
# This file is the TEMPLATE shipped with the repo. It must NOT contain real values.
# Real values live at /opt/papyr/production/.env on the VPS, mode 600 deploy:deploy,
# and are mounted read-only into the container at /app/.env by docker-compose.yml.
# .env.production (without .example) is gitignored.
#
# To create the real file at first deploy (MIG-013):
#   cp .env.production.example .env.production
#   # Edit and fill real values from password manager.
#   # NEVER paste real values into chat or commit them.
#   sudo install -m 600 -o deploy -g deploy .env.production /opt/papyr/production/.env

# Cloudflare R2
R2_ACCOUNT_ID=<from-cloudflare>
R2_ACCESS_KEY_ID=<from-cloudflare>
R2_SECRET_ACCESS_KEY=<from-cloudflare>
R2_BUCKET_NAME=papyr-files

# CORS — allow frontend origin
ALLOWED_ORIGINS=https://mypapyr.com,https://www.mypapyr.com

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
MAX_UPLOAD_SIZE_MB=20
FILE_RETENTION_MINUTES=60

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO
