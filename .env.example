# ========================
# Frontend (Next.js) — copy to frontend/.env.local
# ========================
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_SITE_URL=

# Supabase (standby — belum aktif di MVP 0.1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ========================
# Backend (FastAPI) — copy to backend/.env
# ========================

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# CORS
CORS_ORIGINS=

# App
MAX_UPLOAD_SIZE_MB=20
FILE_RETENTION_MINUTES=60
RATE_LIMIT_PER_MINUTE=10

# Supabase (standby — belum aktif di MVP 0.1)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Sentry (optional)
SENTRY_DSN=
